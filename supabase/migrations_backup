-- Role Permissions Migration
-- Purpose: Create RBAC permission matrix for 4 roles
-- Created: 2026-01-30
-- Module: User Management (Phase 4)

-- Create role_permissions table
CREATE TABLE IF NOT EXISTS role_permissions (
    role VARCHAR(20) NOT NULL,
    resource VARCHAR(50) NOT NULL,
    can_create BOOLEAN DEFAULT false,
    can_read BOOLEAN DEFAULT true,
    can_update BOOLEAN DEFAULT false,
    can_delete BOOLEAN DEFAULT false,
    PRIMARY KEY (role, resource)
);

-- Create index for faster role lookups
/*
CREATE INDEX IF NOT EXISTS idx_role_permissions_role ON role_permissions (role);
*/

-- Create index for resource lookups
/*
CREATE INDEX IF NOT EXISTS idx_role_permissions_resource ON role_permissions (resource);
*/

-- Add comment
COMMENT ON TABLE role_permissions IS 'RBAC permission matrix for 4 roles: super_admin, admin, editor, viewer';

